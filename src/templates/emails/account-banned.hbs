{{#> base-layout}}
{{#*inline "content"}}
<h2 style="color: #721c24; margin: 0 0 20px 0; font-size: 24px;">Account Permanently Banned</h2>

<p style="margin: 0 0 20px 0;">
    Hi {{userName}},
</p>

<p style="margin: 0 0 20px 0;">
    We're writing to inform you that your MentorMinds account has been <strong>permanently banned</strong> due to
    serious violations of our Terms of Service.
</p>

<div
    style="background-color: #f8d7da; padding: 20px; border-radius: 8px; margin: 20px 0; border-left: 4px solid #721c24;">
    <h3 style="margin: 0 0 15px 0; color: #333; font-size: 18px;">Ban Details</h3>
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px; width: 40%;">
                <strong>Reason:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{reason}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Banned On:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                {{banDate}}
            </td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #666; font-size: 14px;">
                <strong>Duration:</strong>
            </td>
            <td style="padding: 8px 0; color: #333; font-size: 14px;">
                Permanent
            </td>
        </tr>
    </table>
</div>

<div
    style="background-color: #fff3cd; padding: 15px; border-radius: 6px; margin: 20px 0; border-left: 4px solid #ffc107;">
    <p style="margin: 0; color: #856404; font-size: 14px;">
        <strong>What This Means:</strong><br>
        &bull; You can no longer access your MentorMinds account<br>
        &bull; All active sessions have been cancelled<br>
        &bull; Any pending payouts will be processed according to our refund policy<br>
        &bull; This ban is permanent and cannot be reversed except through a successful appeal
    </p>
</div>

<div style="text-align: center; margin: 30px 0;">
    <a href="{{appealUrl}}"
        style="display: inline-block; background-color: #4A90E2; color: #ffffff; text-decoration: none; padding: 14px 30px; border-radius: 6px; font-weight: bold; font-size: 16px;">
        Submit an Appeal
    </a>
</div>

<p style="margin: 20px 0 0 0; color: #666; font-size: 14px;">
    If you believe this ban was issued in error, you may submit an appeal by clicking the button above. Our trust and
    safety team will review your case. Please note that appeals are not guaranteed to result in reinstatement.
</p>

<p style="margin: 15px 0 0 0; color: #666; font-size: 14px;">
    For questions, contact us at <a href="mailto:{{supportEmail}}" style="color: #4A90E2;">{{supportEmail}}</a>
</p>
{{/inline}}
{{/base-layout}}
